{
  "name": "pillog-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@pillog/web",
    "dev:mobile": "turbo run dev --filter=@pillog/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "meili:seed": "tsx scripts/meilisearch/seed.ts",
    "meili:sync": "tsx scripts/meilisearch/sync.ts"
  },
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "turbo": "^2.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
